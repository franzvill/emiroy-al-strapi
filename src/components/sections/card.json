{
  "collectionName": "components_sections_cards",
  "info": {
    "displayName": "Card",
    "description": "A card with image and text content"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "ctaText": {
      "type": "string"
    },
    "ctaLink": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "handwritingFont": {
      "type": "enumeration",
      "default": "none",
      "enum": [
        "none",
        "allura",
        "pinyon-script",
        "italianno",
        "parisienne",
        "great-vibes",
        "tangerine",
        "sacramento",
        "petit-formal-script",
        "dancing-script",
        "caveat",
        "homemade-apple",
        "kalam"
      ]
    },
    "handwritingText": {
      "type": "text"
    }
  }
}
